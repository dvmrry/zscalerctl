# Copy this to a local untracked file and keep that file owner-readable only.
# Example:
#   cp examples/zscalerctl.env.example .env
#   chmod 600 .env

ZSCALERCTL_PROFILE=default
ZSCALERCTL_VANITY_DOMAIN=
ZSCALERCTL_CLOUD=PRODUCTION
ZSCALERCTL_CLIENT_ID=

# Prefer a local owner-only file for the client secret.
ZSCALERCTL_CLIENT_SECRET_FILE=

# Inline client-secret variables are intentionally omitted from this example.
# Keep checked-in examples value-free.

ZSCALERCTL_REDACTION=standard
ZSCALERCTL_NO_CACHE=false
